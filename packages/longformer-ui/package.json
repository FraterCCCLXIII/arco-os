{
  "name": "longformer-ui",
  "version": "0.1.0",
  "description": "Longformer UI kit — design tokens, primitives, and workspace views (Chat, Notes, Email, Generated in-line UI) for building AI UI OS style products. Portable: copy the src folder or workspace-import it into any React project.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/tokens/theme.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "zod": "^4.4.3"
  }
}
