{
  "name": "longformer-ui-tailwind",
  "version": "0.1.0",
  "description": "Longformer UI kit (Tailwind edition) — design tokens, primitives, and workspace views styled with Tailwind CSS instead of CSS modules.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/tokens/theme.css",
    "./tailwind.css": "./src/styles/tailwind.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "convert-css": "node scripts/convert-css-to-tailwind.mjs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "postcss": "^8.5.3",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "tailwind-merge": "^3.3.1"
  }
}
